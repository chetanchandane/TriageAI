# LLM (required for triage)
LLM_GEMINI_API_KEY=your_gemini_api_key
# Model name — change here to switch all LLM calls at once
LLM_MODEL=gemini-2.5-pro

# Supabase (optional; if not set, app runs in demo mode with in-memory auth and messages)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Optional: service role key so Staff view can load all patients' messages (bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email via Resend (optional; if not set, emails are printed to console as mock)
# Get your API key at https://resend.com/api-keys
# RESEND_API_KEY=re_your_api_key
# Optional: verified sender address (defaults to onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=TriageAI <triage@yourdomain.com>

# LangSmith tracing (optional; traces appear at smith.langchain.com)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=TriageAI
# LangChain aliases (langchain_core reads these)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=TriageAI
